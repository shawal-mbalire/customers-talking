# Africa's Talking credentials
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key

# Dialogflow CX credentials
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=your-agent-id
DIALOGFLOW_LANGUAGE_CODE=en

# Google credentials (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-in-production
PORT=5000

# Base URL for Voice XML callbacks (set to your public URL in production)
BASE_URL=http://localhost:5000

# Dashboard admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS allowed origin for Angular frontend
FRONTEND_ORIGIN=http://localhost:4200

# Neon Database
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon Auth
NEON_AUTH_BASE_URL=https://ep-xxx.us-east-2.aws.neon.tech/auth
# Optional: override JWKS URL (auto-derived from NEON_AUTH_BASE_URL if not set)
# NEON_AUTH_JWKS_URL=https://ep-xxx.us-east-2.aws.neon.tech/auth/api/auth/jwks
