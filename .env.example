# =============================================================================
# customers-talking — monorepo environment variables
# Copy this file to .env in the relevant directory and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Africa's Talking  (https://africastalking.com)
# -----------------------------------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key

# -----------------------------------------------------------------------------
# Google Dialogflow CX  (https://cloud.google.com/dialogflow)
# -----------------------------------------------------------------------------
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=your-dialogflow-agent-id
DIALOGFLOW_LANGUAGE_CODE=en

# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# -----------------------------------------------------------------------------
# Flask backend
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=change-me-in-production
PORT=5000

# Public base URL — used in Voice XML callbacks; set to your Cloud Run URL in production
BASE_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Angular frontend  (client/public/env.js — not a .env file)
# Update client/public/env.js directly:
#   window.__env = { apiUrl: 'https://your-cloud-run-url' };
# -----------------------------------------------------------------------------

# Dashboard admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS — must match the deployed frontend URL
FRONTEND_ORIGIN=http://localhost:4200
