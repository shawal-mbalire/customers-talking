# =============================================================================
# customers-talking — environment variables
# Copy this file to server/.env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Neon Database  (https://console.neon.tech)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

"postgresql://neondb_owner:npg_whY5MnBq7vou@ep-wispy-wildflower-amn7rko0-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# -----------------------------------------------------------------------------
# Neon Auth  (https://console.neon.tech → Auth tab)
# -----------------------------------------------------------------------------
NEON_AUTH_BASE_URL=https://ep-xxx.us-east-2.aws.neon.tech/auth
# JWKS URL is auto-derived from NEON_AUTH_BASE_URL; only set this if you need to override it
# NEON_AUTH_JWKS_URL=https://ep-xxx.us-east-2.aws.neon.tech/auth/api/auth/jwks

# -----------------------------------------------------------------------------
# Africa's Talking  (https://africastalking.com)
# -----------------------------------------------------------------------------
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key

# -----------------------------------------------------------------------------
# Google Dialogflow CX  (https://cloud.google.com/dialogflow)
# -----------------------------------------------------------------------------
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_LOCATION=global
DIALOGFLOW_AGENT_ID=your-dialogflow-agent-id
DIALOGFLOW_LANGUAGE_CODE=en

# Google Service Account credentials (individual fields — no JSON file needed)
# Find these in your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
# Paste the full private key including -----BEGIN/END----- lines.
# In Cloud Run / Secret Manager, newlines are preserved automatically.
# In a .env file, replace actual newlines with \n (one long line).
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# Flask backend
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=change-me-in-production
# PORT is reserved by Cloud Run (injected automatically); do not set it here.
# For local dev, gunicorn defaults to ${PORT:-8080} or set it in your shell: export PORT=5000

# Public base URL — used in Voice XML callbacks; set to your Cloud Run URL in production
# IMPORTANT: Set this to your Cloud Run URL in production — it's used as the
# callbackUrl in Africa's Talking Voice XML responses.
BASE_URL=http://localhost:8080

# CORS — set to your Firebase Hosting URL in production
FRONTEND_ORIGIN=http://localhost:4200

# -----------------------------------------------------------------------------
# Angular frontend  (client/public/env.js — not a .env file)
# Angular is served by Flask from the same origin; update client/public/env.js for runtime config:
#   window.__env = {
#     apiUrl: 'https://your-cloud-run-url',
#     neonAuthUrl: 'https://ep-xxx.us-east-2.aws.neon.tech/auth'
#   };
# -----------------------------------------------------------------------------
